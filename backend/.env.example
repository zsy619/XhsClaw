# 服务器配置
XHS_SERVER_PORT=8000
XHS_SERVER_MODE=debug
XHS_SERVER_READ_TIMEOUT=60
XHS_SERVER_WRITE_TIMEOUT=60
XHS_SERVER_IDLE_TIMEOUT=120

# 数据库配置
XHS_DATABASE_TYPE=postgres
XHS_DATABASE_HOST=127.0.0.1
XHS_DATABASE_PORT=5432
XHS_DATABASE_USER=postgres
XHS_DATABASE_PASSWORD=123456
XHS_DATABASE_DBNAME=xiaohongshu
XHS_DATABASE_SSLMODE=disable
XHS_DATABASE_MAX_OPEN_CONNS=100
XHS_DATABASE_MAX_IDLE_CONNS=10
XHS_DATABASE_CONN_MAX_LIFETIME=3600
XHS_DATABASE_CONN_MAX_IDLE_TIME=600

# DeepSeek API 配置
XHS_DEEPSEEK_API_KEY=your-deepseek-api-key
XHS_DEEPSEEK_MODEL=deepseek-chat
XHS_DEEPSEEK_BASE_URL=https://api.deepseek.com
XHS_DEEPSEEK_TIMEOUT=120
XHS_DEEPSEEK_MAX_RETRIES=3

# JWT 配置
XHS_JWT_SECRET=your-super-secret-key-change-in-production
XHS_JWT_EXPIRE=24
XHS_JWT_REFRESH_EXPIRE=7
XHS_JWT_ISSUER=xiaohongshu-backend
XHS_JWT_AUDIENCE=xiaohongshu-frontend

# 安全配置 - CORS
XHS_SECURITY_CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
XHS_SECURITY_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
XHS_SECURITY_CORS_ALLOW_HEADERS=Origin,Content-Type,Authorization,X-Requested-With
XHS_SECURITY_CORS_EXPOSE_HEADERS=Content-Length,Content-Type
XHS_SECURITY_CORS_ALLOW_CREDENTIALS=true
XHS_SECURITY_CORS_MAX_AGE=86400

# 安全配置 - 限流
XHS_SECURITY_RATE_LIMIT_ENABLED=true
XHS_SECURITY_RATE_LIMIT_RPS=100.0
XHS_SECURITY_RATE_LIMIT_BURST=200

# 安全配置 - 请求安全
XHS_SECURITY_REQUEST_SECURITY_MAX_BODY_SIZE=10485760
XHS_SECURITY_REQUEST_SECURITY_ENABLE_CSRF=false
XHS_SECURITY_REQUEST_SECURITY_ENABLE_XSS=true
XHS_SECURITY_REQUEST_SECURITY_SECURITY_HEADERS=true
XHS_SECURITY_REQUEST_SECURITY_CONTENT_SECURITY_POLICY="default-src 'self'"
